# ================================================================
# CUARTEL-CRM — Variables de Entorno
# Copiar este archivo como .env.local y completar los valores
# ================================================================

# ── Base de Datos ────────────────────────────────────────────────
# PostgreSQL (Docker Compose: docker compose up -d db)
DATABASE_URL=postgresql://admin:dev_password@localhost:5432/cuartel_crm

# ── Autenticación (NextAuth v5) ──────────────────────────────────
# NextAuth v5 usa AUTH_SECRET (no NEXTAUTH_SECRET)
# Generar con: openssl rand -hex 32   o   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-secret-key-min-32-chars-replace-this
AUTH_URL=http://localhost:3000

# ── Almacenamiento S3-compatible ─────────────────────────────────
# Desarrollo: MinIO (Docker Compose: docker compose up -d minio)
# Producción: AWS S3, Cloudflare R2, Backblaze B2, etc.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=cuartel-media
S3_REGION=us-east-1
# URL pública para acceder a los archivos subidos
S3_PUBLIC_URL=http://localhost:9000/cuartel-media

# ── Correo Electrónico (SMTP) ─────────────────────────────────────
# Desarrollo: Mailpit (Docker Compose: docker compose up -d mailpit)
#   UI en http://localhost:8025
# Producción: SES, Resend, SendGrid, etc.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CUARTEL-CRM <sistema@bomberos163.pe>"

# ── Opcional: Logging / Monitoring ───────────────────────────────
# SENTRY_DSN=https://...
# LOG_LEVEL=info
